{
    "id": "io.github.kmux_project.kmux",
    "branch": "master",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "kmux",
    "finish-args": [
        "--device=all",
        "--share=ipc",
        "--share=network",
        "--socket=wayland",
        "--socket=fallback-x11",
        "--talk-name=org.freedesktop.Flatpak"
    ],
    "modules": [
        {
            "name": "kmux",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DINSTALL_ICONS=ON",
                "-DWITH_LIBSSH=OFF"
            ],
            "sources": [
                { "type": "dir", "path": "." }
            ]
        }
    ]
}
